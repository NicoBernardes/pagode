# Auth Provider Configuration
# Set to "casdoor" to use Casdoor SSO, or "built-in" (default) for built-in auth.
PAGODE_AUTH_PROVIDER=built-in

# Casdoor Configuration (only needed when PAGODE_AUTH_PROVIDER=casdoor)
# See casdoor/README.md for setup instructions.
PAGODE_AUTH_CASDOOR_ENDPOINT=http://localhost:8100
PAGODE_AUTH_CASDOOR_CLIENTID=your-client-id
PAGODE_AUTH_CASDOOR_CLIENTSECRET=your-client-secret
PAGODE_AUTH_CASDOOR_CERTIFICATE="-----BEGIN CERTIFICATE-----\nyour-certificate-here\n-----END CERTIFICATE-----"
PAGODE_AUTH_CASDOOR_ORGANIZATIONNAME=built-in
PAGODE_AUTH_CASDOOR_APPLICATIONNAME=pagode
